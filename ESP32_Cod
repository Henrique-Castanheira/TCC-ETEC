void enviarLeitura(float corrente, float potencia) {
  if (!logado || aparelhoId == -1) return;
  float energia = potencia * (INTERVALO_ENVIO / 1000.0 / 3600.0);




  StaticJsonDocument<200> doc;
  doc["id_aparelho"] = aparelhoId;
  doc["tensao"]      = TENSAO_REDE;
  doc["corrente"]    = corrente;
  doc["potencia"]    = potencia;
  doc["energia_kwh"] = energia;




  String payload;
  serializeJson(doc, payload);
  int code = httpPost(String(API_BASE) + "/api/leitura", payload);
  Serial.print("Envio → HTTP "); Serial.println(code);
}




