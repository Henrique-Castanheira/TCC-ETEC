// ==========================================
void setup() {
  Serial.begin(115200);
  lcd.init();
  lcd.backlight();




  // --- WiFiManager ------------------------------------------------
  WiFiManager wm;
  wm.setTitle("Choki Energy");
  wm.setConfigPortalTimeout(180); // fecha portal após 3 min sem configurar




  lcd.clear();
  lcd.setCursor(0, 0); lcd.print("Configurando...");
  lcd.setCursor(0, 1); lcd.print("Choki-Setup");




  // Se já tem credenciais salvas → conecta direto (sem abrir hotspot)
  // Se não tem → cria hotspot "Choki-Setup" com senha "choki1234"
  bool conectado = wm.autoConnect("Choki-Setup", "choki1234");




  if (!conectado) {
    lcd.clear();
    lcd.setCursor(0, 0); lcd.print("Timeout WiFi");
    lcd.setCursor(0, 1); lcd.print("Reiniciando...");
    delay(2000);
    ESP.restart();
  }
  // ----------------------------------------------------------------




  // --- mDNS -------------------------------------------------------
  if (MDNS.begin(HOSTNAME)) {
    Serial.println("mDNS OK → http://choki.local");
  }
  // ----------------------------------------------------------------




  lcd.clear();
  lcd.setCursor(0, 0); lcd.print("WiFi OK!");
  lcd.setCursor(0, 1); lcd.print(WiFi.localIP());
  delay(2000);




  server.on("/",            HTTP_GET,  paginaLogin);
  server.on("/login",       HTTP_POST, processarLogin);
  server.on("/dash",        HTTP_GET,  paginaDash);
  server.on("/aparelhos",   HTTP_GET,  paginaAparelhos);
  server.on("/selecionar",  HTTP_GET,  selecionarAparelho);
  server.on("/leituras",    HTTP_GET,  paginaLeituras);
  server.on("/perfil",      HTTP_GET,  paginaPerfil);
  server.on("/logout",      HTTP_GET,  logout);
  server.on("/reset-wifi",  HTTP_GET,  resetWifi); // ← NOVO
  server.begin();




  lcd.clear();
  lcd.setCursor(0, 0); lcd.print("choki.local");
  lcd.setCursor(0, 1); lcd.print(WiFi.localIP());
}




// ==========================================
// LOOP
// ==========================================
void loop() {
  server.handleClient();
  // MDNS.update();  ❌ REMOVIDO (não existe no ESP32)


  if (!logado || aparelhoId == -1) return;


  leituraCorrente = 0.0;
  leituraPotencia = 0.0;


  unsigned long agora = millis();


  if (agora - ultimoEnvio >= INTERVALO_ENVIO) {
    ultimoEnvio = agora;
    enviarLeitura(leituraCorrente, leituraPotencia);
  }


  if (agora - ultimaExibicao >= INTERVALO_TELA) {
    ultimaExibicao = agora;
    lcd.clear();
    switch (telaAtual) {
      case 0:
        lcd.setCursor(0, 0); lcd.print("Ola, " + usuarioNome.substring(0, 10) + "!");
        lcd.setCursor(0, 1); lcd.print(aparelhoNome.substring(0, 16));
        break;
      case 1:
        lcd.setCursor(0, 0); lcd.print("Corrente:");
        lcd.setCursor(0, 1); lcd.print("I:" + String(leituraCorrente, 2) + "A");
        break;
      case 2:
        lcd.setCursor(0, 0); lcd.print("V:" + String(TENSAO_REDE, 0) + "V");
        lcd.setCursor(0, 1); lcd.print("P:" + String(leituraPotencia, 1) + "W");
        break;
    }
    telaAtual = (telaAtual + 1) % 3;
  }
}
