String httpGet(String url) {
  HTTPClient http;
  http.begin(url);
  http.setTimeout(12000);
  int code = http.GET();
  String body = (code == 200) ? http.getString() : "[]";
  http.end();
  return body;
}




int httpPost(String url, String payload) {
  HTTPClient http;
  http.begin(url);
  http.addHeader("Content-Type", "application/json");
  http.setTimeout(12000);
  int code = http.POST(payload);
  http.end();
  return code;
}




