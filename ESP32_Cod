void paginaAparelhos() {
  if (!logado) { server.sendHeader("Location", "/"); server.send(302); return; }




  String bodyAp = httpGet(String(API_BASE) + "/api/aparelho/" + usuarioId);
  String cards  = "";




  DynamicJsonDocument docAp(1024);
  if (!deserializeJson(docAp, bodyAp)) {
    JsonArray arr = docAp.as<JsonArray>();
    for (JsonObject ap : arr) {
      int    id    = ap["id"];
      String nome  = ap["nome"].as<String>();
      String desc  = ap["descricao"].as<String>();
      float  horas = ap["horas_uso_dia"] | 0.0;
      int    dias  = ap["dias_uso_mes"]  | 0;
      bool   sel   = (id == aparelhoId);




      cards += "<a class='ap-card' href='/selecionar?id=" + String(id) + "&nome=" + nome + "'>";
      cards += "<div class='card' style='" + String(sel ? "border-color:#238636" : "") + "'>";
      cards += "<div style='display:flex;justify-content:space-between;align-items:flex-start'>";
      cards += "<div><strong>" + nome + "</strong>";
      if (sel) cards += " <span class='badge badge-g'>monitorando</span>";
      cards += "<p style='color:#8b949e;font-size:12px;margin-top:5px'>" + desc + "</p>";
      cards += "<p style='color:#8b949e;font-size:12px;margin-top:3px'>⏱ " + String(horas, 0) + "h/dia · 📅 " + String(dias) + " dias/mês</p>";
      cards += "</div><span style='font-size:28px'>🔌</span></div></div></a>";
    }
    if (cards == "") cards = "<div class='card'><p style='color:#8b949e;text-align:center'>Nenhum aparelho cadastrado</p></div>";
