void processarLogin() {
  String email = server.arg("email");
  String senha  = server.arg("senha");




  StaticJsonDocument<200> req;
  req["email"]    = email;
  req["password"] = senha;
  String payload;
  serializeJson(req, payload);




  HTTPClient http;
  http.begin(String(API_BASE) + "/api/login");
  http.addHeader("Content-Type", "application/json");
  http.setTimeout(12000);
  int code = http.POST(payload);
  String body = http.getString();
  http.end();




  if (code == 200) {
    DynamicJsonDocument doc(512);
    deserializeJson(doc, body);
    usuarioId     = doc["id"];
    usuarioNome   = doc["username"].as<String>();
    usuarioEmail  = doc["email"].as<String>();
    usuarioTarifa = doc["tarifa_eletrica"] | 0.0;
    logado        = true;




    lcd.clear();
    lcd.setCursor(0, 0); lcd.print("Ola, " + usuarioNome.substring(0, 10) + "!");
    lcd.setCursor(0, 1); lcd.print("Bem-vindo!");




    server.sendHeader("Location", "/dash");
    server.send(302);
  } else {
    server.sendHeader("Location", "/?erro=1");
    server.send(302);
  }
}




