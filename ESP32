// Define o pino do LED integrado (geralmente GPIO 2 ou 15)
const int ledPin = 2; 

void setup() {
  // Configura o pino do LED como saída
  pinMode(ledPin, OUTPUT);
}

void loop() {
  digitalWrite(ledPin, HIGH); // Liga o LED (nível lógico alto)
  delay(1000);                // Espera 1 segundo (1000 milissegundos)
  digitalWrite(ledPin, LOW);  // Desliga o LED (nível lógico baixo)
  delay(1000);                // Espera 1 segundo
}
